root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,mjs,cjs,ts,tsx,html,css,scss,json,jsonc,yaml,yml,md}]
indent_style = space
indent_size = 2

[*.{py,sh,bash}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.{md,mdx}]
trim_trailing_whitespace = false

[{package.json,package-lock.json}]
indent_style = space
indent_size = 2
