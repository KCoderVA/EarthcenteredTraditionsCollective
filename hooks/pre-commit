#!/usr/bin/env bash
# pre-commit hook for Earthcentered Traditions Collective
# Runs ESLint, Prettier, and html-validate on staged files.
# Exit non-zero to block the commit if any check fails.

set -euo pipefail

PASS=true
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🌿 Running pre-commit checks…"
echo ""

# ============================================================
# Get staged files
# ============================================================
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$' || true)
STAGED_CSS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.css$' || true)
STAGED_HTML=$(git diff --cached --name-only --diff-filter=ACM | grep '\.html$' || true)
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM || true)

# ============================================================
# ESLint on staged JS files
# ============================================================
if [ -n "$STAGED_JS" ]; then
  echo "🔍 Running ESLint on staged .js files…"
  # shellcheck disable=SC2086
  if ! npx eslint $STAGED_JS --no-eslintrc -c .eslintrc.json; then
    echo -e "${RED}❌ ESLint failed. Please fix the errors above before committing.${NC}"
    PASS=false
  else
    echo -e "${GREEN}✅ ESLint passed.${NC}"
  fi
  echo ""
fi

# ============================================================
# Prettier check on all staged files
# ============================================================
if [ -n "$STAGED_ALL" ]; then
  echo "💅 Checking Prettier formatting on staged files…"
  # shellcheck disable=SC2086
  if ! npx prettier --check $STAGED_ALL; then
    echo -e "${RED}❌ Prettier check failed.${NC}"
    echo -e "${YELLOW}   Run 'npm run format' to fix formatting, then re-stage the files.${NC}"
    PASS=false
  else
    echo -e "${GREEN}✅ Prettier check passed.${NC}"
  fi
  echo ""
fi

# ============================================================
# html-validate on staged HTML files
# ============================================================
if [ -n "$STAGED_HTML" ]; then
  echo "🏷️  Validating staged .html files…"
  # shellcheck disable=SC2086
  if ! npx html-validate $STAGED_HTML; then
    echo -e "${RED}❌ HTML validation failed. Please fix the errors above before committing.${NC}"
    PASS=false
  else
    echo -e "${GREEN}✅ HTML validation passed.${NC}"
  fi
  echo ""
fi

# ============================================================
# Final result
# ============================================================
if [ "$PASS" = false ]; then
  echo -e "${RED}🚫 Pre-commit checks failed. Commit blocked.${NC}"
  echo "   Fix the issues above, then run: git add -p && git commit"
  echo ""
  echo "   To skip checks (use sparingly): git commit --no-verify"
  exit 1
else
  echo -e "${GREEN}🌿 All pre-commit checks passed. Committing…${NC}"
  exit 0
fi
