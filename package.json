{
  "name": "earthcentered-traditions-collective",
  "version": "0.1.0",
  "description": "Website for the Earthcentered Traditions Collective — a local extracurricular religious club celebrating earth-centered spiritual traditions.",
  "private": true,
  "keywords": [
    "earthcentered",
    "traditions",
    "collective",
    "religious-club",
    "community",
    "static-site"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KCoderVA/EarthcenteredTraditionsCollective.git"
  },
  "homepage": "https://kcoderva.github.io/EarthcenteredTraditionsCollective",
  "author": "KCoderVA",
  "scripts": {
    "dev": "live-server src/public --port=5500 --host=localhost --open=/index.html",
    "build": "node scripts/build.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:html": "node scripts/validate-html.js",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint:all": "npm-run-all lint stylelint validate:html",
    "ci": "npm-run-all lint:all format:check test",
    "postinstall": "node scripts/setup-hooks.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "html-validate": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/__tests__/**/*.js", "**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "!src/**/*.min.js"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
